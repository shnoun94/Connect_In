{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/"
    },
    {
      "src": "/resources/(.*)",
      "dest": "/public/resources/"
    },
    {
      "src": "/favicon/(.*)",
      "dest": "/public/favicon/"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env" : {
    "APP_ENV": "production"
  }
}
